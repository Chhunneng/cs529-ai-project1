## Shared (docker-compose)
COMPOSE_PROJECT_NAME=ai-resume-agent

## Postgres
POSTGRES_DB=resume_agent
POSTGRES_USER=resume_agent
POSTGRES_PASSWORD=resume_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

## Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

## Backend
BACKEND_HOST=backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://resume_agent:resume_agent@postgres:5432/resume_agent
REDIS_URL=redis://redis:6379/0
LOG_LEVEL=INFO

## OpenAI
# Put your real key in `.env`, not here.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5-nano

## PDF compile (worker -> backend internal endpoint)
# Default in docker-compose: http://backend:8000/api/v1/internal
LATEX_SERVICE_URL=http://backend:8000/api/v1/internal
# Optional: if set, worker sends X-Internal-Token; backend requires the same value
INTERNAL_COMPILE_TOKEN=

## Shared PDF artifacts (backend serves GET /resume-outputs/{id}/pdf)
ARTIFACTS_DIR=/data/artifacts
TEMPLATES_BASE_DIR=/app/templates

## Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
