# Copy to `.env` and fill in secrets. Do not commit `.env`.
#
# Docker Compose loads this file for backend, worker, and (via substitution) services.
# For backend/worker run locally (outside Docker), point DATABASE_URL and REDIS_URL at localhost.

## —— Docker Compose (optional) ——
COMPOSE_PROJECT_NAME=ai-resume-agent

## —— Postgres (docker-compose postgres service) ——
POSTGRES_DB=resume_agent
POSTGRES_USER=resume_agent
POSTGRES_PASSWORD=resume_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

## —— Redis ——
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

## —— Backend / worker (required) ——
# Inside Docker: hostnames `postgres` and `redis`. On your machine: `127.0.0.1`
DATABASE_URL=postgresql+asyncpg://resume_agent:resume_agent@postgres:5432/resume_agent
REDIS_URL=redis://redis:6379/0

# Logging: DEBUG, INFO, WARNING, …
LOG_LEVEL=INFO

# Redis list key for background jobs (chat, PDF render, resume parse). Usually leave default.
# QUEUE_KEY=queue:agent-jobs

## —— OpenAI ——
# Required for chat, resume JSON extraction (worker), and template fill. Put the real key only in `.env`.
OPENAI_API_KEY=
# Model for Responses API (chat, resume parse, etc.)
OPENAI_MODEL=gpt-5-nano

## —— Resume uploads (API saves files here; maps to ./data/resume-uploads in docker-compose) ——
RESUME_UPLOADS_DIR=/data/resume-uploads
# Max uploaded file size in bytes (default 10 MiB)
# RESUME_UPLOAD_MAX_BYTES=10485760
# Max characters of extracted text sent to the resume parser (default 24000)
# RESUME_EXTRACT_MAX_INPUT_CHARS=24000

## —— PDF / LaTeX artifacts (compiled PDFs; maps to ./data/artifacts in docker-compose) ——
ARTIFACTS_DIR=/data/artifacts

# Worker calls this URL to compile LaTeX. Default matches Docker service name `backend`.
LATEX_SERVICE_URL=http://backend:8000/api/v1/internal
# If set, worker sends X-Internal-Token and backend validates it on /api/v1/internal/*
INTERNAL_COMPILE_TOKEN=

## —— Frontend (build-time / runtime in Docker) ——
# Browser-visible API base (no trailing slash). Use http://localhost:8000 when API is on host port 8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

## —— Convenience (not read by app code; documentation only) ——
BACKEND_HOST=backend
BACKEND_PORT=8000
