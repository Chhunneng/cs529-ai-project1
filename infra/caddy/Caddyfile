:80 {
:  encode gzip
:
:  # Route API calls to the backend container.
:  handle_path /api/* {
:    reverse_proxy backend:8000
:  }
:
:  # Backend health endpoint (used by compose healthcheck).
:  handle_path /healthz {
:    reverse_proxy backend:8000
:  }
:
:  # Everything else goes to the Next.js frontend.
:  handle {
:    reverse_proxy frontend:3000
:  }
:}

